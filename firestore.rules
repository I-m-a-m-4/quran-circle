rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email.toLowerCase() == 'belloimam431@gmail.com';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User Profile Rules
    match /users/{userId} {
      // Allow read if user is logged in
      allow read: if isAuthenticated();
      // Only the user themselves can write/edit their profile, OR the admin (Imam Bello) can update it (e.g. to send nudges)
      allow write: if isOwner(userId) || isAdmin();
    }
    
    // Accountability Circles Rules
    match /circles/{circleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        request.auth.uid in resource.data.members ||
        isAdmin()
      );
    }
    
    // Reflections and Activity Timeline Rules
    match /posts/{postId} {
      allow read: if isAuthenticated();
      // Allow writing if user is posting as themselves, or if they are admin
      allow create: if isAuthenticated() && (request.resource.data.email.toLowerCase() == request.auth.token.email.toLowerCase() || isAdmin());
      allow update, delete: if isAuthenticated() && (resource.data.email.toLowerCase() == request.auth.token.email.toLowerCase() || isAdmin());
    }
    
    // User Activity logs
    match /activities/{activityId} {
      // Anyone can read (to show active status, or history check)
      allow read: if isAuthenticated();
      // Create if they are logging their own activity
      allow create: if isAuthenticated() && (request.resource.data.email.toLowerCase() == request.auth.token.email.toLowerCase() || isAdmin());
      allow update, delete: if isAuthenticated() && (resource.data.email.toLowerCase() == request.auth.token.email.toLowerCase() || isAdmin());
    }

    // Live Chats Rules
    match /chats/{chatId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.resource.data.email.toLowerCase() == request.auth.token.email.toLowerCase() || isAdmin());
      allow update, delete: if isAdmin();
    }
  }
}
